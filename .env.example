# ==========================================
# NANOBOT - ENVIRONMENT VARIABLES TEMPLATE
# ==========================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena los valores con tus credenciales reales
# 3. NUNCA subas el archivo .env a git
#
# ==========================================

# === API KEYS (REQUERIDO) ===
GEMINI_API_KEY=your_gemini_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === TRADING PARAMETERS ===
INITIAL_CAPITAL=10000
RISK_PER_TRADE=0.004
KELLY_FRACTION=0.25

# === MT5 CONFIGURATION ===
MT5_PORT=8001
MT5_TIMEOUT=30

# === AI CONFIGURATION ===
AI_MODEL=gemini/gemini-2.0-flash
AI_TEMPERATURE=0.7

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FILE_RETENTION_DAYS=7

# === OPTIONAL: ADVANCED ===
# ENABLE_BACKTESTING=false
# BACKTEST_START_DATE=2024-01-01
# BACKTEST_END_DATE=2024-12-31
