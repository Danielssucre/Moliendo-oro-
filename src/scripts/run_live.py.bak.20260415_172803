    logger.info("⚡ Entering 24/7 Signal Scan Loop...")

    # Track sent signals to enforce DAILY RE-ENTRY
    # {pair: 'YYYY-MM-DD'}
    last_signal_date = {}

    last_pulse_time = time.time()

    print(f"⏳ Scanning... (Ctrl+C to stop)")

    while True:
        try:
            # Globals for components
            global market_guardian, orchestrator, meta_selector, guardian, polimata_v6
            logger.debug("--- [STEP 0] Loop Start ---")
            iteration_exposed_symbols = set()  # Local tracking for current iteration

            # 0. Connection Watchdog & Offline Pulse Guard
            # We check connection but ALSO send a heartbeat if we've been offline too long
            is_connected = mt5_manager.ensure_connected()
            if not is_connected:
                if time.time() - last_pulse_time > 60:
                    last_pulse_time = time.time()
                    if bot.enabled:
                        bot.send_message(
                            "💓 *STATUS PULSE* 💓\n🛰️ Link: OFFLINE (Broker/Terminal Down)\n💤 Waiting for recovery..."
                        )
                    logger.info("💓 Offline Pulse Sent to Telegram")

                logger.error("❌ Link Lost. Waiting for recovery...")
                time.sleep(5)
                continue
            logger.debug("--- [STEP 1] Connection Verified ---")

            # Update account info EVERY iteration
            acc = mt5_client.account_info()
            if not acc:
                logger.warning("⚠️ Failed to get account info. Skipping iteration.")
                time.sleep(1)
                continue

            equity = acc.equity
            balance = acc.balance
            daily_pnl = equity - INITIAL_CAPITAL
            is_small_cap = balance < 100
            is_survival_mode = balance < 50

            # --- [SUNDAY MODE: PERFORMANCE FAVOR] ---
            # If it's Sunday, we favor background training. Reduce loop frequency.
            is_sunday = datetime.now().weekday() == 6
            if is_sunday:
                logger.info(
                    "🛌 [SUNDAY MODE] Markets closed. Polling slowly to favor background training..."
                )
                time.sleep(30)

            # Check for AI Retraining
            check_auto_retrain()

            # --- [UNIVERSAL GUARDIAN v4.1: SYSTEM PROTECTION] ---
            if not guardian:
                guardian = UniversalGuardian(INITIAL_CAPITAL, logger)

            guardian.update(equity)

            # --- [KILL-SWITCH] ---
            if guardian.check_daily_stop(mt5_client, equity, is_survival_mode):
                time.sleep(60)  # Chill for a minute if stop hit
                continue

            # --- PHASE 26: TELEGRAM PULSE (Heartbeat) ---
            # PRIORITIZED: Move pulse to the very top to give user feedback immediately.
            if time.time() - last_pulse_time > 60:  # Every 60 seconds
                last_pulse_time = time.time()
                try:
                    if MT5_CONNECTED:
                        positions = mt5_client.positions_get()

                        global daily_stats
                        if datetime.now().strftime("%Y-%m-%d") != daily_stats["date"]:
                            daily_stats = {
                                "date": datetime.now().strftime("%Y-%m-%d"),
                                "trades_won": 0,
                                "trades_lost": 0,
                                "best_trade": 0.0,
                                "worst_trade": 0.0,
                                "champion_pnl": 0.0,
                                "champion_trades": 0,
                                "neme_pnl": 0.0,
                                "neme_trades": 0,
                                "crypto_pnl": 0.0,
                                "crypto_trades": 0,
                                "peak_equity": 0.0,
                                "min_equity": float("inf"),
                            }
                            save_daily_stats()

                        daily_stats["peak_equity"] = max(
                            daily_stats["peak_equity"], equity
                        )
                        if equity < daily_stats["min_equity"]:
                            daily_stats["min_equity"] = equity

                        max_dd = 0.0
                        if daily_stats["peak_equity"] > INITIAL_CAPITAL:
                            max_dd = (
                                (daily_stats["peak_equity"] - equity)
                                / daily_stats["peak_equity"]
                            ) * 100

                        total_trades_day = (
                            daily_stats["trades_won"] + daily_stats["trades_lost"]
                        )

                        pnl_pct = (
                            (daily_pnl / INITIAL_CAPITAL) * 100
                            if INITIAL_CAPITAL > 0
                            else 0
                        )

                        polimata_conf = 0
                        if polimata_v6 and hasattr(polimata_v6, "get_confidence"):
                            polimata_conf = polimata_v6.get_confidence()

                        now_ny = (
                            datetime.now(timezone.utc).astimezone().tzname() or "UTC"
                        )
                        ny_time = (
                            datetime.now(timezone.utc).astimezone().strftime("%H:%M")
