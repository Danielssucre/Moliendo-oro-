# --- VIRTUAL ORDER MANAGER (SHADOW GRID) ---


def calculate_lot_by_risk(symbol, risk_usd, sl_dist):
    """
    Calculates the exact lot size for a desired USD risk and Stop Loss distance.
    Formula: Lot = RiskUSD / (SL_Points * TickValuePerPoint)
    """
    try:
        # Resolve MT5 symbol
        symbol_mt5 = symbol
        try:
            from src.scripts.run_live import MT5_SYMBOL_MAP

            symbol_mt5 = MT5_SYMBOL_MAP.get(symbol, symbol)
        except:
            pass

        info = mt5_client.symbol_info(symbol_mt5)
        if not info or sl_dist <= 0:
            return 0.01

        tick_value = info.trade_tick_value
        tick_size = info.trade_tick_size
        point = info.point

        if tick_value == 0 or tick_size == 0:
            return 0.01

        # Calculate points from price distance
        points_dist = sl_dist / point

        # TickValue is USD per 1.0 Lot per 1.0 TickSize
        # Risk = Lot * (points_dist / (tick_size/point)) * tick_value
        # Lot = Risk / [ (points_dist * point / tick_size) * tick_value ]

        lot = risk_usd / ((sl_dist / tick_size) * tick_value)

        # Adjust for symbol precision and limits
        lot = round(lot, 2)
        lot = max(info.volume_min, min(info.volume_max, lot))

        return lot
    except Exception as e:
        logger.error(f"Error calculating lot for {symbol}: {e}")
        return 0.01


