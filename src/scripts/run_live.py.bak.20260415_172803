                                    continue

                                logger.info(
                                    f"✅ [2/5] HIVE PASSED: {pair} (ADX={adx_val:.1f}, Vol={current_vol:.1f})"
                                )
                            if bot.enabled:
                                bot.send_message(
                                    f"📡 *Signal Detected:* `{pair}` (`{source_tag}`) | ADX: {adx_val:.1f}\nProcessing Laboratorio L-H-N..."
                                )

                            # 2. Market Regime & ML Check
                            # CRYPTO_LAB usa datos de Binance, régimen diferente
                            if is_crypto_source:
                                regime = (
                                    "TRENDING"  # Crypto opera en trending por defecto
                                )
                                logger.info(
                                    f"📊 [3/6] MARKET REGIME: {pair} is {regime} (Crypto Mode)"
                                )
                            else:
                                prev = data.iloc[-2] if len(data) > 1 else row
                                adx_slope = row["adx"] - prev["adx"]
                                # [CHAMPION + NEME PRIME] Detector de régimen para control de mercado
                                # TRENDING (ADX >= 25): CHAMPION opera
                                # CALM_RANGE (ADX < 20): NEME PRIME opera
                                # CHAOTIC (vol > 0.5%): SKIP - No operar
                                regime = (
                                    "TRENDING"
                                    if adx_val >= 25
                                    else "CALM_RANGE"
                                    if adx_val < 20
                                    else "CHAOTIC"
                                )
                                logger.info(
                                    f"📊 [3/6] MARKET REGIME: {pair} is {regime} (ADX={adx_val:.1f})"
                                )

                                # [CHAMPION + NEME PRIME] Skip si mercado es caótico
                                if regime == "CHAOTIC":
                                    logger.info(
                                        f"⏸️ [REGIME SKIP] {pair} en régimen CHAOTIC. No se opera."
                                    )
                                    continue

                            ml_risk_score = 0.5  # Default
                            prob_success = 0.5  # Default
                            prob_val = 0.5  # Fix for NameError
                            confidence_factor = 1.0

                            # --- PHASE 23: QUANTUM RISK ORACLE (Asymmetric Sizing) ---
                            bayesian_mult = 1.0
                            if RISK_ORACLE_ENABLED and risk_oracle:
                                if ML_ENABLED and stop_hunt_model:
                                    try:
                                        features = stop_hunt_model.extract_features(
                                            data,
                                            row["close"],
                                            {
                                                "rsi": row["rsi"],
                                                "adx": row["adx"],
                                                "atr": row["atr"],
                                                "vwap": row["close"],
                                            },
                                        )
                                        ml_risk_score = stop_hunt_model.predict_risk(
                                            features
                                        )
                                        prob_success = 1.0 - ml_risk_score
                                        # --- CINTURÓN DE SEGURIDAD PRO-BENEFIT (Mejora Daniel B) ---
                                        # Límite de exposición correlacionada por DIVISA BASE (Max 15 lotes)
                                        exposure_heat = 0.0
                                        currency_exposure = {}  # {EUR: lots, GBP: lots, etc.}

                                        if MT5_CONNECTED:
                                            from src.nanobot.ml.risk_oracle import (
                                                calculate_portfolio_heat,
                                            )

                                            positions = mt5_client.positions_get()
                                            if positions:
                                                for p in positions:
                                                    base_curr = p.symbol[:3]
                                                    currency_exposure[base_curr] = (
                                                        currency_exposure.get(
                                                            base_curr, 0
                                                        )
                                                        + p.volume
                                                    )
                                                    exposure_heat += p.volume

                                        # Verificar si el par actual sobrepasa el límite de su divisa base
                                        # [EXPOSURE/CORRELATION LIMIT REMOVED]
                                        pass

                                        # Calculate Portfolio Heat (Total current risk)
                                        acc = mt5_client.account_info()
                                        if acc:
                                            account_peak = max(
                                                account_peak, float(acc.balance)
                                            )
                                            current_dd = (
                                                account_peak - float(acc.balance)
                                            ) / account_peak
                                        else:
                                            current_dd = 0.0

                                        # Quantum RL/Math Sizing!
                                        bayesian_mult = (
                                            risk_oracle.calculate_sizing_multiplier(
                                                probability=prob_success,
                                                reward_risk=1.5,
                                                current_dd=current_dd,
                                                exposure_heat=exposure_heat,
                                                adx=adx_val,
                                                rsi=row["rsi"],
                                                vol=current_vol,
                                                symbol=pair,
                                            )
                                        )

                                        # --- CHAMPION + NEME THRESHOLD ---
                                        # Lowered from 75% to 50% to allow more signals
                                        is_valid_trade = True
                                        prob_threshold = 0.50  # CHAMPION threshold
                                        if prob_success < prob_threshold:
                                            logger.info(
                                                f"⚖️ [PROB VETO] {pair} Prob={prob_success:.2%} (Threshold {prob_threshold:.0%}) -> Low probability"
                                            )
                                            is_valid_trade = False

                                        if bayesian_mult <= 0:
                                            logger.info(
                                                f"⚖️ [ORACLE SKIP] {pair} Neutral edge -> Data Grid Only"
                                            )
                                            is_valid_trade = False

                                    except Exception as e:
                                        logger.error(
                                            f"Risk Oracle/ML Error ({pair}): {e}"
                                        )
                                        bayesian_mult = 1.0

                                # Check if trade is valid before executing
                                if not is_valid_trade:
                                    logger.info(
                                        f"🚫 [BLOCKED] {pair} - Low probability (Prob={prob_success:.2%})"
                                    )
                                    continue

                                logger.info(
                                    f"🦖 [EXECUTION / DATA COLLECTION] {pair} @ {row['close']:.4f}"
                                )
                                entry_price = row["close"]

                                # --- SECONDARY WHITELIST VETO [REMOVED] ---

                                # --- MARKET STATUS CHECK ---
                                symbol_info = mt5_client.symbol_info(pair)
                                if symbol_info is None or not symbol_info.visible:
                                    logger.warning(
                                        f"⚠️ {pair} NOT visible/valid on MT5. Skipping."
                                    )
                                    continue

                                if (
                                    symbol_info.trade_mode
                                    == mt5_client.SYMBOL_TRADE_MODE_DISABLED
                                ):
                                    logger.warning(
                                        f"⚠️ {pair} Trade DISABLED. Skipping."
                                    )
                                    last_signal_date[pair] = (
                                        current_hour_tag  # Don't loop
                                    )
                                    continue

                                # --- TIME FENCING & CHAMELEON LOGIC (Based on Data Sciencer Insight) ---
                                tick = mt5_client.symbol_info_tick(pair)
                                if tick:
                                    current_mt5_hour = datetime.fromtimestamp(
                                        tick.time
                                    ).hour
                                else:
                                    current_mt5_hour = datetime.now().hour  # Fallback

                                # --- 1. Institutional Lot Sizing (0.1% Risk vs 0.5% Champion) ---
                                acc_info = mt5_client.account_info()

                                # Define baseline SL/TP distances (ATR-based for ALFA/Sizing)
                                # CRYPTO_LAB: usar ATR de Binance si existe
                                if is_crypto_source:
                                    sl_dist = (
                                        float(row.get("atr", row["close"] * 0.01)) * 1.5
                                    )  # 1.5% default SL
                                else:
                                    sl_dist = float(row["atr"]) * 1.5
                                tp_dist = sl_dist * 2.0  # Default RR

                                if acc_info:
                                    # [CHAMPION LOGIC] Apply 0.5% base risk for Nemesis
                                    is_neme = (
                                        source_tag == "NEME"
                                        or "NEME" in strategy.upper()
                                        or "NEMESIS" in strategy.upper()
                                    )
                                    risk_pct = 0.005 if is_neme else 0.001

                                    lots_calculated = (
                                        guardian.calculate_progressive_lot(
                                            float(acc_info.balance),
                                            symbol_info,
                                            sl_dist,
                                            risk_pct=risk_pct,
                                        )
                                    )

                                    # Apply Quant Oracle Multiplier (2.5x for Champion)
                                    final_mult = bayesian_mult if is_neme else 1.0
                                    lots_calculated = lots_calculated * final_mult

                                    # Apply guardian scalars
                                    scalar = (
                                        guardian.get_scalar_multiplier(equity)
                                        if "guardian" in locals()
                                        else 1.0
                                    )
                                    lots_calculated = lots_calculated * scalar
                                else:
                                    lots_calculated = 0.01

                                # --- 2. EXECUTION PROTOCOLS (Universal Router) ---
                                # [ALREADY DEFINED ABOVE] is_neme = ...

                                # NEMESIS CHAMPION: ATR-based Recovery (Institutional)
                                # [CHAMPION + NEME PRIME + CRYPTO_LAB] - Bloqueado: ALFA, EXPL, WINNER
                                is_crypto = any(
                                    c in pair.upper() for c in ["BTC", "ETH", "SOL"]
                                )
                                is_neme_or_crypto = (
                                    is_neme or is_crypto or source_tag == "CRYPTO_LAB"
                                )

                                if is_neme_or_crypto:
                                    # Check Nemesis Safety Cap (Max 3 positions)
                                    neme_count = 0
                                    if positions:
                                        for p in positions:
                                            if (
                                                "NEME" in p.comment
                                                or "CRYPTO" in p.comment
                                            ):
                                                neme_count += 1

                                    if neme_count >= 3:
                                        logger.warning(
                                            f"🛑 [STRATEGY CAP] {neme_count}/3 posiciones activas. Protegiendo cuenta."
                                        )
                                        continue

                                    n_sl = (
                                        float(entry_price) - sl_dist
                                        if sig == 1
                                        else float(entry_price) + sl_dist
                                    )
                                    # Champion Target: RR 2.5
                                    n_tp = (
                                        float(entry_price) + (sl_dist * 2.5)
                                        if sig == 1
                                        else float(entry_price) - (sl_dist * 2.5)
                                    )
                                    n_order = (
                                        "BS (Buy Stop)"
                                        if sig == 1
                                        else "SS (Sell Stop)"
                                    )

                                    # Comment based on source
                                    if is_crypto:
                                        comment = "CRYPTO_LAB"
                                        desc = f"🪙 *CRYPTO LAB*\nPair: `{pair}` | RR: 2.5x\nSource: {strategy}"
                                    else:
                                        comment = "CHAM_NEME_LIVE"
                                        desc = f"🏆 *NÉMESIS CAMPEÓN*\nPair: `{pair}` | RR: 2.5x\nStatus: Institutional High Confidence"

                                    pending_basket.append(
                                        {
                                            "pair": pair,
                                            "type": n_order,
                                            "price": float(entry_price),
                                            "sl": n_sl,
                                            "tp": n_tp,
                                            "lots": lots_calculated,
                                            "comment": comment,
                                            "desc": desc,
                                            "prob_success": float(prob_success),
                                        }
                                    )
                                    detected_symbols.add(pair.upper())
                                    logger.info(
                                        f"✅ [EXECUTION QUEUE] {pair} añadido a pending_basket (Source: {source_tag})"
                                    )
                                else:
                                    # Solo Forex non-NEME es bloqueado
                                    logger.debug(
                                        f"🚫 [STRATEGY BLOCKED] Solo CHAMPION/NEME para Forex. {pair} saltado."
                                    )
                                    continue

                                # --- MASSIVE DATA COLLECTION (MEGA GRID) ---
                                # Check if Mega Grid is enabled in config
                                mega_grid_enabled = True
                                try:
                                    with open("config/trading_config.json", "r") as f:
                                        tmp_cfg = json.load(f)
                                        mega_grid_enabled = tmp_cfg.get(
                                            "mega_grid_enabled", True
                                        )
                                except:
                                    pass

                                if mega_grid_enabled and not is_small_cap:
                                    dist_ema200 = (
                                        float(entry_price) - row["ema_200"]
                                    ) / row["ema_200"]

                                    virtual_manager.register_signal_pool(
                                        pair,
                                        entry_price,
                                        row["atr"],
                                        adx_val,
                                        row["rsi"],
                                        current_vol,
                                        prob_success,
                                        sig,
                                        dist_ema200=dist_ema200,
                                        source=source_tag,
                                    )

                                    if bot.enabled and source_tag == "LHN":
                                        bot.send_message(
                                            f"📡 *MEGA GRID SENSOR (25/25/25/25)*\nPair: `{pair}` | Grid: Balanced 40 variants."
                                        )
                                    elif bot.enabled:
                                        bot.send_message(
                                            f"🧪 *EXPERIMENTAL TRIGGER*\nPair: `{pair}` | Precision Lab Grid (8 variants)."
                                        )
                                else:
                                    logger.info(
                                        f"🛡️ [MEGA GRID OFF] Skipping data collection for {pair}."
                                    )

                                last_signal_date[signal_key] = current_hour_tag

                except Exception as e:
                    import traceback

                    tb_str = traceback.format_exc()
                    logger.error(f"Iter Error ({pair}): {e}\n{tb_str}")

            # --- PHASE 95: SYNC GATE AUTHORIZATION & BATCH EXECUTION (DYNAMIC V2) ---
            if pending_basket:
                try:
                    active_pos = mt5_client.positions_get()
                    active_count = len(active_pos) if active_pos else 0

                    sync_authorized = False
                    auth_reason = ""

                    # --- REGLA BASE: CONSENSO MACROECONÓMICO ---
                    if len(detected_symbols) >= SYNC_GATE_MIN_BASKET:
                        sync_authorized = True
                        auth_reason = (
                            f"Consenso (N>={SYNC_GATE_MIN_BASKET} Simultáneos)"
                        )

                    # --- EXCEPCIÓN 1: ABSOLUTE ALPHA (SOLO TRADE DE ÉLITE) ---
                    elif active_count == 0 and len(detected_symbols) == 1:
                        trade = pending_basket[0]
                        prob_ai = trade.get("prob_success", 0.0)
                        if prob_ai > 0.65:
                            sync_authorized = True
                            auth_reason = (
                                f"Alpha Élite (DQN-Prob: {prob_ai * 100:.1f}%)"
                            )
                        else:
                            auth_reason = f"Señal débil descartada (DQN-Prob: {prob_ai * 100:.1f}% <= 65.0%)"

                    # --- EXCEPCIÓN 2: REFUERZOS BLINDADOS (CORRELATION CHECK) ---
                    elif active_count >= 1:
                        if len(detected_symbols) == 1:
                            trade = pending_basket[0]
                            # Bloqueamos el refuerzo si violenta los límites base de la Fase 4
                            safe_correlation = check_correlation_exposure(
                                trade["pair"], trade["type"]
                            )

                            if safe_correlation:
                                sync_authorized = True
                                auth_reason = "Refuerzo Validado por Correlación"
                            else:
                                auth_reason = f"Refuerzo Rechazado (Sobreexposición en Vena USD/Correlada)"
                        else:
                            sync_authorized = True
                            auth_reason = "Múltiples Refuerzos Simultáneos"

                    # --- DISPATCH DE ÓRDENES ---
                    if sync_authorized:
                        logger.info(
                            f"📡 [SYNC GATE OPEN] Razón: {auth_reason} | Active Context: {active_count} positions."
                        )
                        for trade in pending_basket:
                            try:
                                res = execute_mt5_trade(
                                    trade["pair"],
                                    trade["type"],
                                    trade["price"],
                                    trade["sl"],
                                    trade["tp"],
                                    trade["lots"],
                                    comment=trade["comment"],
                                )
                                if res and res.retcode in [
                                    mt5_client.TRADE_RETCODE_DONE,
                                    mt5_client.TRADE_RETCODE_PLACED,
                                ]:
                                    iteration_exposed_symbols.add(trade["pair"].upper())
                                    if bot.enabled:
                                        bot.send_message(
                                            f"✅ *AUTHORIZED: {auth_reason}*\n{trade['desc']}"
                                        )
                            except Exception as e:
                                logger.error(
                                    f"Sync Gate Execution Error ({trade['pair']}): {e}"
                                )
                    else:
                        logger.info(
                            f"⚖️ [SYNC GATE LOCKED] {auth_reason}. Descartando cesta."
                        )
                        if (
                            bot.enabled
                            and len(detected_symbols) > 0
                            and len(detected_symbols) < SYNC_GATE_MIN_BASKET
                        ):
                            bot.send_message(
                                f"🔒 *SYNC GATE LOCKED*\nPair: {list(detected_symbols)[0]}\nRazón: {auth_reason}"
                            )
                except Exception as e:
                    logger.error(f"Sync Gate Logic Error: {e}")

            # --- UPDATE LHN REAL GRID (Check tickets) ---
            if MT5_CONNECTED:
                virtual_manager.update()

            time.sleep(1)  # Fast scan

        except KeyboardInterrupt:
            print("\n🛑 Stopped.")
            if MT5_CONNECTED:
                mt5_client.shutdown()
            break
        except Exception as e:
            logger.error(f"💥 CRITICAL LOOP ERROR: {e}")
            logger.info("🛡️ [RESILIENCY] Attempting self-recovery in 15 seconds...")
            time.sleep(15)
            # Restart loop for clean state
            continue


def nightly_polimata_retrain():
    import subprocess

    while True:
        try:
            now = datetime.now()
            target = now.replace(hour=23, minute=55, second=0, microsecond=0)
            if now > target:
                target += timedelta(days=1)
            sleep_seconds = (target - now).total_seconds()

            logger.info(
                f"🧠 Next Polimata sleep cycle in {sleep_seconds / 3600:.1f} hrs"
            )
            time.sleep(sleep_seconds)

            logger.info("🧠 POLIMATA REM SLEEP INITIATED (Auto-Retraining)...")
            if bot.enabled:
                bot.send_message(
                    "🧠 *Polimata REM Sleep*\nInitiating daily data assimilation..."
                )

            # Execute retraining script
            script_path = os.path.join(
                os.path.dirname(os.path.abspath(__file__)), "retrain_polimata.py"
            )
            subprocess.run([sys.executable, script_path], check=True)

            # No model reload needed - Polimata V7 Forex uses rule-based validation

        except Exception as e:
            logger.error(f"⚠️ Error in Polimata REM Sleep: {e}")
            time.sleep(3600)  # Sleep an hour before retrying on crash


if __name__ == "__main__":
    # import threading
    # polimata_thread = threading.Thread(target=nightly_polimata_retrain, daemon=True)
    # polimata_thread.start()
    main()
